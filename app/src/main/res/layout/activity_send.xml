<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/activity_send_root"
        android:orientation="vertical"
        android:padding="6dp">

    <!--    add send button container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/add_container"
            android:layout_width="match_parent"
            android:layout_height="50dp">

    <!--        add button -->
        <ImageView
            android:id="@+id/add_send_btn"
            android:layout_width="@dimen/add_icon_size"
            android:layout_height="@dimen/add_icon_size"
            style="@style/ADD_ICON"
            android:contentDescription="@string/add_label"
            app:layout_constraintTop_toTopOf="@id/add_container"
            app:layout_constraintBottom_toBottomOf="@id/add_container"
            app:layout_constraintRight_toRightOf="@id/add_container"
            app:layout_constraintLeft_toLeftOf="@id/add_container"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>