<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:padding="@dimen/padding_4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp"/>

        <TextView
            style="@style/TEXT"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="@dimen/panel_title_size"
            android:layout_marginTop="@dimen/margin_20dp"
            android:text="@string/settings"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp"/>

        <!--        theme mode (light | dark)-->
        <LinearLayout
            android:layout_marginVertical="@dimen/space_divider_settings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height"
            android:orientation="horizontal">

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

            <TextView
                style="@style/TEXT"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:layout_weight="1"
                android:text="@string/theme_mode_label"
                android:textSize="@dimen/message_text_size" />

            <Spinner
                android:id="@+id/theme_mode_dropdown"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:spinnerMode="dropdown"
                android:popupBackground="?attr/app_backgroundColor"/>

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

        </LinearLayout>

<!--        select default panel-->
        <LinearLayout
            android:layout_marginVertical="@dimen/space_divider_settings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height"
            android:orientation="horizontal">

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

            <TextView
                style="@style/TEXT"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:layout_weight="1"
                android:text="@string/default_panel_label"
                android:textSize="@dimen/message_text_size" />

            <Spinner
                android:id="@+id/default_panel_dropdown"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginVertical="8dp"
                android:spinnerMode="dropdown"
                android:popupBackground="?attr/app_backgroundColor"/>

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

        </LinearLayout>

        <!--        time limit to store messages in chat-->
        <LinearLayout
            android:layout_marginVertical="@dimen/space_divider_settings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height"
            android:orientation="horizontal">

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/time_limit_msg_label"
                android:textSize="@dimen/message_text_size"
                style="@style/TEXT" />


            <EditText
                android:id="@+id/limit_time_msg_input"
                android:layout_width="50dp"
                android:layout_height="match_parent"
                android:inputType="number"
                android:text="7"
                android:textSize="@dimen/message_text_size"
                android:textAlignment="center"/>

            <Space
                android:layout_width="30dp"
                android:layout_height="match_parent"/>

        </LinearLayout>

<!--        disable notification checkbox-->
        <LinearLayout
            android:layout_marginVertical="@dimen/space_divider_settings"
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height"
            android:orientation="horizontal">

            <Space
                android:layout_width="@dimen/margin_20dp"
                android:layout_height="match_parent"/>

            <TextView
                style="@style/TEXT"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/message_text_size"
                android:text="@string/disable_notification_settings"/>

            <CheckBox
                android:id="@+id/enable_notification_btn"
                android:layout_width="@dimen/settings_item_height"
                android:layout_height="match_parent"
                android:checked="true"
                android:text=""/>

            <Space
                android:layout_width="30dp"
                android:layout_height="match_parent"/>

        </LinearLayout>

        <!--        about section-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_marginVertical="@dimen/space_divider_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/about_title_settings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                android:text="@string/about_subtitle"
                android:textSize="20sp"
                style="@style/TEXT"/>

            <TextView
                android:id="@+id/about_label"
                android:layout_marginTop="@dimen/margin_20dp"
                android:textSize="15sp"
                android:textAlignment="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="40dp"
                app:layout_constraintTop_toBottomOf="@id/about_title_settings"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                android:text="@string/about_label"/>

            <Button
                android:id="@+id/github_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/github_project_label"
                app:layout_constraintTop_toBottomOf="@id/about_label"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginVertical="@dimen/margin_20dp"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    <!--    check update button-->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/settings_item_height">

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/check_updates_btn"
                android:text="@string/check_updates"
                app:icon="?attr/app_updateIcon"
                app:iconGravity="textStart"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp"/>

    </LinearLayout>

</ScrollView>