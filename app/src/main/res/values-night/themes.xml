<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Mqitty" parent="Theme.Material3.DayNight.NoActionBar">
<!--        dark theme-->
        <item name="app_color">@color/primary_text_dark</item>
        <item name="app_background">@color/background_dark</item>
        <item name="app_backgroundColor">@color/third_background_dark</item>
        <item name="app_colorBackgroundFloating">@color/elevated_background_dark</item>
        <item name="app_hintTextColor">@color/secondary_text_dark</item>

        <item name="colorPrimary">@color/highlight_dark</item>
        <item name="colorOnPrimary">@color/primary_text_dark</item>

        <item name="colorSecondary">@color/secondary_highlight</item>
        <item name="colorOnSecondary">@color/secondary_text_dark</item>

        <item name="app_updateIcon">@drawable/update_white</item>

        <item name="android:statusBarColor">?attr/app_colorPrimaryVariant</item>
    </style>

    <style name="SCREEN">
        <item name="android:background">?attr/app_background</item>
    </style>

    <style name="HEADER_BG">
        <item name="android:background">@drawable/header_gradient_dark</item>
    </style>


    <!--    text color-->
    <style name="TEXT">
        <item name="android:textColor">?attr/app_color</item>
    </style>

    <!--    icon navigation bar-->
    <!--    send-->
    <style name="SEND_ICON">
        <item name="android:src">@drawable/send_white</item>
    </style>
    <!--    receive-->
    <style name="RECEIVE_ICON">
        <item name="android:src">@drawable/receive_white</item>
    </style>
    <!--    settings-->
    <style name="SETTINGS_ICON">
        <item name="android:src">@drawable/settings_white</item>
    </style>
    <!--    filter-->
    <style name="FILTER_ICON">
        <item name="android:src">@drawable/filter_white</item>
    </style>
    <!--    search-->
    <style name="SEARCH_ICON">
        <item name="android:src">@drawable/search_white</item>
    </style>
    <!--    add-->
    <style name="ADD_ICON">
        <item name="android:src">@drawable/add_white</item>
    </style>
    <!--    play-->
    <style name="PLAY_ICON">
        <item name="android:src">@drawable/play_white</item>
    </style>
    <!--    pause-->
    <style name="PAUSE_ICON">
        <item name="android:src">@drawable/pause_white</item>
    </style>
    <!--    return-->
    <style name="RETURN_ICON">
        <item name="android:src">@drawable/arrow_back_white</item>
    </style>
    <!--    three dots-->
    <style name="THREE_DOTS_ICON">
        <item name="android:src">@drawable/three_dots_white</item>
    </style>

    <style name="RADIO_BUTTON" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="android:button">@null</item>
        <item name="android:background">@drawable/radio_button_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_marginHorizontal">8dp</item>
        <item name="android:textColor">?attr/app_color</item>
    </style>

    <style name="FILTER_TOGGLE_BUTTON">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:drawableStart">@drawable/filter_toggle_indicator</item>
        <item name="android:drawablePadding">8dp</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:textColor">?attr/app_color</item>
        <item name="android:paddingHorizontal">4dp</item>
    </style>

    <style name="Theme.Mqitty" parent="Base.Theme.Mqitty" />

    <!-- Custom Theme for Update Dialog -->
    <style name="UpdateDialogTheme" parent="Theme.Material3.DayNight.Dialog.Alert">
        <item name="android:windowBackground">?attr/app_backgroundColor</item>
        <item name="android:textColorPrimary">?attr/app_color</item>
        <item name="android:textColorSecondary">?attr/app_hintTextColor</item>
        <item name="colorAccent">?attr/colorPrimary</item>
        <item name="borderRound">@dimen/border_radius_10dp</item>
        <item name="buttonBarButtonStyle">@style/Widget.AppCompat.Button</item>
    </style>
</resources>