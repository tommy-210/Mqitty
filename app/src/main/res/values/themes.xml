<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Mqitty" parent="Theme.Material3.DayNight.NoActionBar">
<!--        light theme-->
        <item name="app_color">@color/black</item>
        <item name="app_background">@color/background_light</item>
        <item name="app_backgroundColor">@color/subheader_background_light</item>
        <item name="app_colorBackgroundFloating">@color/elevated_background_light</item>
        <item name="app_hintTextColor">@color/disabled_text</item>

        <item name="colorPrimary">@color/primary_highlight</item>
<!--        <item name="colorPrimaryVariant">@color/royal_blue</item>-->
        <item name="colorOnPrimary">@color/primary_text</item>

        <item name="colorSecondary">@color/secondary_highlight</item>
<!--        <item name="colorSecondaryVariant">@color/violet</item>-->
        <item name="colorOnSecondary">@color/secondary_text</item>

    </style>

<!--    light mode-->
<!--    screen background-->
    <style name="SCREEN">
        <item name="android:background">?attr/app_background</item>
    </style>

    <style name="HEADER_BG">
        <item name="android:background">@drawable/header_gradient_light</item>
    </style>

<!--    text color-->
    <style name="TEXT">
        <item name="android:textColor">?attr/app_color</item>
    </style>

<!--    icon navigation bar-->
<!--    send-->
    <style name="SEND_ICON">
        <item name="android:src">@drawable/send_black</item>
    </style>
<!--    receive-->
    <style name="RECEIVE_ICON">
        <item name="android:src">@drawable/receive_black</item>
    </style>
<!--    settings-->
    <style name="SETTINGS_ICON">
        <item name="android:src">@drawable/settings_black</item>
    </style>
<!--    filter-->
    <style name="FILTER_ICON">
        <item name="android:src">@drawable/filter_black</item>
    </style>
<!--    search-->
    <style name="SEARCH_ICON">
        <item name="android:src">@drawable/search_black</item>
    </style>
<!--    add-->
    <style name="ADD_ICON">
        <item name="android:src">@drawable/add_black</item>
    </style>
<!--    play-->
    <style name="PLAY_ICON">
        <item name="android:src">@drawable/play_black</item>
    </style>
<!--    pause-->
    <style name="PAUSE_ICON">
        <item name="android:src">@drawable/pause_black</item>
    </style>
<!--    return-->
    <style name="RETURN_ICON">
        <item name="android:src">@drawable/arrow_back_black</item>
    </style>
<!--    three dots-->
    <style name="THREE_DOTS_ICON">
        <item name="android:src">@drawable/three_dots_black</item>
    </style>

    <style name="Theme.Mqitty" parent="Base.Theme.Mqitty" />
</resources>