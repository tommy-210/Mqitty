<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Mqitty" parent="Theme.Material3.DayNight.NoActionBar">
<!--        light theme-->
        <item name="color">@color/black</item>
        <item name="background">@color/bright_snow</item>
        <item name="colorBackgroundFloating">@color/alabaster_gray</item>
        <item name="backgroundColor">@color/pale_slate</item>
        <item name="hintTextColor">@color/pale_slate_gray</item>

        <item name="colorPrimary">@color/blue_light</item>
<!--        <item name="colorPrimaryVariant">@color/blue</item>-->
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/blue</item>
<!--        <item name="colorSecondaryVariant">@color/violet</item>-->
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:statusBarColor">?attr/colorPrimary</item>
    </style>

<!--    light mode-->
<!--    screen background-->
    <style name="SCREEN">
        <item name="backgroundColor">@color/bright_snow</item>
    </style>
    
<!--    text color-->
    <style name="TEXT">
        <item name="android:textColor">@color/black</item>
    </style>

<!--    icon navigation bar-->
<!--    send-->
    <style name="SEND_ICON">
        <item name="android:src">@drawable/send_black</item>
    </style>
<!--    receive-->
    <style name="RECEIVE_ICON">
        <item name="android:src">@drawable/receive_black</item>
    </style>
<!--    settings-->
    <style name="SETTINGS_ICON">
        <item name="android:src">@drawable/settings_black</item>
    </style>
<!--    filter-->
    <style name="FILTER_ICON">
        <item name="android:src">@drawable/filter_black</item>
    </style>
<!--    search-->
    <style name="SEARCH_ICON">
        <item name="android:src">@drawable/search_black</item>
    </style>
<!--    add-->
    <style name="ADD_ICON">
        <item name="android:src">@drawable/add_black</item>
    </style>
<!--    play-->
    <style name="PLAY_ICON">
        <item name="android:src">@drawable/play_black</item>
    </style>
<!--    pause-->
    <style name="PAUSE_ICON">
        <item name="android:src">@drawable/pause_black</item>
    </style>
<!--    return-->
    <style name="RETURN_ICON">
        <item name="android:src">@drawable/arrow_back_black</item>
    </style>

    <style name="Theme.Mqitty" parent="Base.Theme.Mqitty" />
</resources>